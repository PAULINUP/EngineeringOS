}

KNOWLEDGE eco.29-2-demand-and-supply-shifts-in-foreign-exchange-markets.v1 INTERMEDIATE {
  title: "29.2 Demand and Supply Shifts in Foreign Exchange Markets"
  domain: "economia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Explain supply and demand for exchange rates; Define arbitrage; Explain purchasing power parity's importance when comparing countries.."
  requires: [eco.29-1-how-the-foreign-exchange-market-works.v1]
  interactivity: 5
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Principles of Economics 3e - 29.2 Demand and Supply Shifts in Foreign Exchange Markets", weight: 0.90 }
