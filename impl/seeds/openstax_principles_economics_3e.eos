  domain: "economia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Explain how exchange rate shifting influences aggregate demand and supply; Explain how shifting exchange rates also can influence loans and banks."
  requires: [eco.29-2-demand-and-supply-shifts-in-foreign-exchange-markets.v1]
  interactivity: 5
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Principles of Economics 3e - 29.3 Macroeconomic Effects of Exchange Rates", weight: 0.90 }
}

KNOWLEDGE eco.29-4-exchange-rate-policies.v1 INTERMEDIATE {
  title: "29.4 Exchange Rate Policies"
  domain: "economia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Differentiate among a floating exchange rate, a soft peg, a hard peg, and a merged currency; Identify the tradeoffs that come with a floating exchange rate, a soft peg, a hard peg, and a merged currency."
  requires: [eco.29-3-macroeconomic-effects-of-exchange-rates.v1]
  interactivity: 5
  decay_rate: 0.03
