  definition: "Ao final desta secao, voce sera capaz de: Explain the reason for open market operations; Evaluate reserve requirements and discount rates; Interpret and show bank activity through balance sheets; Distinguish between monetary policy in an environment of limited reserves and monetary policy in an environment of ample reserves."
  requires: [eco.28-2-bank-regulation.v1]
  interactivity: 5
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Principles of Economics 3e - 28.3 How a Central Bank Executes Monetary Policy", weight: 0.90 }
}

KNOWLEDGE eco.28-4-monetary-policy-and-economic-outcomes.v1 INTERMEDIATE {
  title: "28.4 Monetary Policy and Economic Outcomes"
  domain: "economia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Contrast expansionary monetary policy and contractionary monetary policy; Explain how monetary policy impacts interest rates and aggregate demand; Evaluate Federal Reserve decisions over the last forty years; Explain the significance of quantitative easing (QE)."
  requires: [eco.28-3-how-a-central-bank-executes-monetary-policy.v1]
  interactivity: 5
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Principles of Economics 3e - 28.4 Monetary Policy and Economic Outcomes", weight: 0.90 }
}

KNOWLEDGE eco.28-5-pitfalls-for-monetary-policy.v1 INTERMEDIATE {
  title: "28.5 Pitfalls for Monetary Policy"
  domain: "economia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Analyze whether monetary policy decisions should be made more democratically; Calculate the velocity of money; Evaluate the central bank’s influence on inflation, unemployment, asset bubbles, and leverage cycles; Calculate the effects of monetary stimulus."
  requires: [eco.28-4-monetary-policy-and-economic-outcomes.v1]
  interactivity: 5
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Principles of Economics 3e - 28.5 Pitfalls for Monetary Policy", weight: 0.90 }
}

