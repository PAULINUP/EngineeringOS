    eco.3-2-shifts-in-demand-and-supply-for-goods-and-services.v1,
    eco.3-3-changes-in-equilibrium-price-and-quantity-the-four-step-process.v1,
    eco.3-4-price-ceilings-and-price-floors.v1,
    eco.3-5-demand-supply-and-efficiency.v1,
    eco.4-1-demand-and-supply-at-work-in-labor-markets.v1,
    eco.4-2-demand-and-supply-in-financial-markets.v1,
    eco.4-3-the-market-system-as-an-efficient-mechanism-for-information.v1,
    eco.5-1-price-elasticity-of-demand-and-price-elasticity-of-supply.v1,
    eco.5-2-polar-cases-of-elasticity-and-constant-elasticity.v1,
    eco.5-3-elasticity-and-pricing.v1,
    eco.5-4-elasticity-in-areas-other-than-price.v1,
    eco.6-1-consumption-choices.v1,
    eco.6-2-how-changes-in-income-and-prices-affect-consumption-choices.v1,
    eco.6-3-behavioral-economics-an-alternative-framework-for-consumer-choice.v1,
    eco.7-1-explicit-and-implicit-costs-and-accounting-and-economic-profit.v1,
    eco.7-2-production-in-the-short-run.v1,
    eco.7-3-costs-in-the-short-run.v1,
    eco.7-4-production-in-the-long-run.v1,
    eco.7-5-costs-in-the-long-run.v1,
    eco.8-1-perfect-competition-and-why-it-matters.v1,
