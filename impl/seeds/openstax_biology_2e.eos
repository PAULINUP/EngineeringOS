  title: "45.4 Population Dynamics and Regulation"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Give examples of how the carrying capacity of a habitat may change; Compare and contrast density-dependent growth regulation and density-independent growth regulation, giving examples; Give examples of exponential and logistic growth in wild animal populations; Describe how natural selection and environmental adaptation leads to the evolution of particular life-history patterns."
  requires: [bio2.45-3-environmental-limits-to-population-growth.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 45.4 Population Dynamics and Regulation", weight: 0.90 }
}

KNOWLEDGE bio2.45-5-human-population-growth.v1 ADVANCED {
  title: "45.5 Human Population Growth"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Discuss exponential human population growth; Explain how humans have expanded the carrying capacity of their habitat; Relate population growth and age structure to the level of economic development in different countries; Discuss the long-term implications of unchecked human population growth."
  requires: [bio2.45-4-population-dynamics-and-regulation.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 45.5 Human Population Growth", weight: 0.90 }
}

KNOWLEDGE bio2.45-6-community-ecology.v1 ADVANCED {
  title: "45.6 Community Ecology"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Discuss the predator-prey cycle; Give examples of defenses against predation and herbivory; Describe the competitive exclusion principle; Give examples of symbiotic relationships between species; Describe community structure and succession."
  requires: [bio2.45-5-human-population-growth.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 45.6 Community Ecology", weight: 0.90 }
}

KNOWLEDGE bio2.45-7-behavioral-biology-proximate-and-ultimate-causes-of-behavior.v1 ADVANCED {
  title: "45.7 Behavioral Biology: Proximate and Ultimate Causes of Behavior"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Compare innate and learned behavior; Discuss how movement and migration behaviors are a result of natural selection; Discuss the different ways members of a population communicate with each other; Give examples of how species use energy for mating displays and other courtship behaviors; Differentiate between various mating systems; Describe different ways that species learn."
  requires: [bio2.45-6-community-ecology.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 45.7 Behavioral Biology: Proximate and Ultimate Causes of Behavior", weight: 0.90 }
}

# ------------------------------------------------------------
# CAPITULO 46: 46 Ecosystems
# ------------------------------------------------------------
KNOWLEDGE bio2.46-1-ecology-of-ecosystems.v1 ADVANCED {
  title: "46.1 Ecology of Ecosystems"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Describe the basic ecosystem types; Explain the methods that ecologists use to study ecosystem structure and dynamics; Identify the different methods of ecosystem modeling; Differentiate between food chains and food webs and recognize the importance of each."
  requires: [bio2.45-7-behavioral-biology-proximate-and-ultimate-causes-of-behavior.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 46.1 Ecology of Ecosystems", weight: 0.90 }
}

KNOWLEDGE bio2.46-2-energy-flow-through-ecosystems.v1 ADVANCED {
  title: "46.2 Energy Flow through Ecosystems"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Describe how organisms acquire energy in a food web and in associated food chains; Explain how the efficiency of energy transfers between trophic levels affects ecosystem structure and dynamics; Discuss trophic levels and how ecological pyramids are used to model them."
  requires: [bio2.46-1-ecology-of-ecosystems.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 46.2 Energy Flow through Ecosystems", weight: 0.90 }
}

KNOWLEDGE bio2.46-3-biogeochemical-cycles.v1 ADVANCED {
  title: "46.3 Biogeochemical Cycles"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Discuss the biogeochemical cycles of water, carbon, nitrogen, phosphorus, and sulfur; Explain how human activities have impacted these cycles and the potential consequences for Earth."
  requires: [bio2.46-2-energy-flow-through-ecosystems.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 46.3 Biogeochemical Cycles", weight: 0.90 }
}

# ------------------------------------------------------------
# CAPITULO 47: 47 Conservation Biology and Biodiversity
# ------------------------------------------------------------
KNOWLEDGE bio2.47-1-the-biodiversity-crisis.v1 ADVANCED {
  title: "47.1 The Biodiversity Crisis"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Define biodiversity in terms of species diversity and abundance; Describe biodiversity as the equilibrium of naturally fluctuating rates of extinction and speciation; Identify historical causes of high extinction rates in Earth’s history."
  requires: [bio2.46-3-biogeochemical-cycles.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 47.1 The Biodiversity Crisis", weight: 0.90 }
}

