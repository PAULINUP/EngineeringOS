  title: "47.2 The Importance of Biodiversity to Human Life"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Identify chemical diversity benefits to humans; Identify biodiversity components that support human agriculture; Describe ecosystem services."
  requires: [bio2.47-1-the-biodiversity-crisis.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 47.2 The Importance of Biodiversity to Human Life", weight: 0.90 }
}

KNOWLEDGE bio2.47-3-threats-to-biodiversity.v1 ADVANCED {
  title: "47.3 Threats to Biodiversity"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Identify significant threats to biodiversity; Explain the effects of habitat loss, the introduction of exotic species, and hunting on biodiversity; Identify the early and predicted effects of climate change on biodiversity."
  requires: [bio2.47-2-the-importance-of-biodiversity-to-human-life.v1]
  interactivity: 6
  decay_rate: 0.03
  source: { type: "standard", ref: "OpenStax: Biology 2e - 47.3 Threats to Biodiversity", weight: 0.90 }
}

KNOWLEDGE bio2.47-4-preserving-biodiversity.v1 ADVANCED {
  title: "47.4 Preserving Biodiversity"
  domain: "biologia_faculdade"
  definition: "Ao final desta secao, voce sera capaz de: Identify new technologies and methods for describing biodiversity; Explain the legislative framework for conservation; Describe principles and challenges of conservation preserve design; Identify examples of the effects of habitat restoration; Discuss the role of zoos in biodiversity conservation."
  requires: [bio2.47-3-threats-to-biodiversity.v1]
